{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable", "WebWorker"],
    "paths": {
      "or-tools-wasm": ["../javascript/lib/index.ts"],
      "or-tools-wasm/cp-sat": ["../javascript/lib/cp-sat.ts"],
      "or-tools-wasm/routing": ["../javascript/lib/routing.ts"],
      "or-tools-wasm/mathopt": ["../javascript/lib/mathopt.ts"],
      "or-tools-wasm/mp-solver": ["../javascript/lib/mp-solver.ts"],
      "or-tools-wasm/pdlp": ["../javascript/lib/pdlp.ts"],
      "or-tools-wasm/knapsack": ["../javascript/lib/knapsack.ts"],
      "or-tools-wasm/network-flow": ["../javascript/lib/network-flow.ts"],
      "or-tools-wasm/set-cover": ["../javascript/lib/set-cover.ts"],
      "or-tools-wasm/rcpsp": ["../javascript/lib/rcpsp.ts"],
      "protobufjs": ["./node_modules/protobufjs/index.d.ts"],
      "protobufjs/*": ["./node_modules/protobufjs/*"],
      "@internal-wasm/*": ["build/javascript/wasm/*"],
      "#internal-wasm/*": ["build/javascript/wasm/*"]
    }
  },
  "include": [
    "../javascript/lib/**/*.ts",
    "../javascript/lib/**/*.d.ts",
    "build/javascript/wasm/**/*.d.ts"
  ]
}
