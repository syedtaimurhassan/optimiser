{
  "name": "or-tools-wasm",
  "private": false,
  "version": "0.9.1",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Axelwickm/or-tools-wasm.git"
  },
  "homepage": "https://github.com/Axelwickm/or-tools-wasm",
  "bugs": {
    "url": "https://github.com/Axelwickm/or-tools-wasm/issues"
  },
  "type": "module",
  "main": "./build/javascript/node/index.js",
  "types": "./build/javascript/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/javascript/lib/index.d.ts",
      "bun": "./build/javascript/node/index.js",
      "deno": "./build/javascript/node/index.js",
      "node": "./build/javascript/node/index.js",
      "browser": "./build/javascript/browser/index.js",
      "import": "./build/javascript/browser/index.js",
      "default": "./build/javascript/browser/index.js"
    },
    "./cp-sat": {
      "types": "./build/javascript/lib/cp-sat.d.ts",
      "bun": "./build/javascript/node/cp-sat.js",
      "deno": "./build/javascript/node/cp-sat.js",
      "node": "./build/javascript/node/cp-sat.js",
      "browser": "./build/javascript/browser/cp-sat.js",
      "import": "./build/javascript/browser/cp-sat.js",
      "default": "./build/javascript/browser/cp-sat.js"
    },
    "./routing": {
      "types": "./build/javascript/lib/routing.d.ts",
      "bun": "./build/javascript/node/routing.js",
      "deno": "./build/javascript/node/routing.js",
      "node": "./build/javascript/node/routing.js",
      "browser": "./build/javascript/browser/routing.js",
      "import": "./build/javascript/browser/routing.js",
      "default": "./build/javascript/browser/routing.js"
    },
    "./mathopt": {
      "types": "./build/javascript/lib/mathopt.d.ts",
      "bun": "./build/javascript/node/mathopt.js",
      "deno": "./build/javascript/node/mathopt.js",
      "node": "./build/javascript/node/mathopt.js",
      "browser": "./build/javascript/browser/mathopt.js",
      "import": "./build/javascript/browser/mathopt.js",
      "default": "./build/javascript/browser/mathopt.js"
    },
    "./mp-solver": {
      "types": "./build/javascript/lib/mp-solver.d.ts",
      "bun": "./build/javascript/node/mp-solver.js",
      "deno": "./build/javascript/node/mp-solver.js",
      "node": "./build/javascript/node/mp-solver.js",
      "browser": "./build/javascript/browser/mp-solver.js",
      "import": "./build/javascript/browser/mp-solver.js",
      "default": "./build/javascript/browser/mp-solver.js"
    },
    "./pdlp": {
      "types": "./build/javascript/lib/pdlp.d.ts",
      "bun": "./build/javascript/node/pdlp.js",
      "deno": "./build/javascript/node/pdlp.js",
      "node": "./build/javascript/node/pdlp.js",
      "browser": "./build/javascript/browser/pdlp.js",
      "import": "./build/javascript/browser/pdlp.js",
      "default": "./build/javascript/browser/pdlp.js"
    },
    "./knapsack": {
      "types": "./build/javascript/lib/knapsack.d.ts",
      "bun": "./build/javascript/node/knapsack.js",
      "deno": "./build/javascript/node/knapsack.js",
      "node": "./build/javascript/node/knapsack.js",
      "browser": "./build/javascript/browser/knapsack.js",
      "import": "./build/javascript/browser/knapsack.js",
      "default": "./build/javascript/browser/knapsack.js"
    },
    "./network-flow": {
      "types": "./build/javascript/lib/network-flow.d.ts",
      "bun": "./build/javascript/node/network-flow.js",
      "deno": "./build/javascript/node/network-flow.js",
      "node": "./build/javascript/node/network-flow.js",
      "browser": "./build/javascript/browser/network-flow.js",
      "import": "./build/javascript/browser/network-flow.js",
      "default": "./build/javascript/browser/network-flow.js"
    },
    "./set-cover": {
      "types": "./build/javascript/lib/set-cover.d.ts",
      "bun": "./build/javascript/node/set-cover.js",
      "deno": "./build/javascript/node/set-cover.js",
      "node": "./build/javascript/node/set-cover.js",
      "browser": "./build/javascript/browser/set-cover.js",
      "import": "./build/javascript/browser/set-cover.js",
      "default": "./build/javascript/browser/set-cover.js"
    },
    "./rcpsp": {
      "types": "./build/javascript/lib/rcpsp.d.ts",
      "bun": "./build/javascript/node/rcpsp.js",
      "deno": "./build/javascript/node/rcpsp.js",
      "node": "./build/javascript/node/rcpsp.js",
      "browser": "./build/javascript/browser/rcpsp.js",
      "import": "./build/javascript/browser/rcpsp.js",
      "default": "./build/javascript/browser/rcpsp.js"
    },
    "./build/javascript/lib/*": "./build/javascript/lib/*"
  },
  "imports": {
    "#internal-wasm/*": "./build/javascript/wasm/*"
  },
  "scripts": {
    "build:wasm": "bash ../scripts/build_wasm.sh",
    "build:wasm:clean": "ORTOOLS_WASM_CLEAN=1 bash ../scripts/build_wasm.sh",
    "gen:sat-parameters": "node ../scripts/generate_sat_parameters_types.mjs",
    "patch:wasm-runtime": "node ../scripts/patch_emscripten_runtime.mjs",
    "build:lib": "npm run build:wasm && npm run patch:wasm-runtime && npm run gen:sat-parameters && tsc --project tsconfig.json && vite build --config vite.lib.config.ts && node ../scripts/build_browser_sources.mjs && node ../scripts/build_node_sources.mjs",
    "build:site": "vite build --config vite.site.config.ts",
    "build": "npm run build:lib && npm run build:site",
    "dev": "npm run build:lib && vite --config vite.site.config.ts dev --host",
    "pack:lib": "npm run build:lib && npm pack --pack-destination build/javascript/lib",
    "clean": "rm -rf build",
    "package": "npm run build && npm pack",
    "prepack": "node ../scripts/prepare_package_readme.mjs",
    "start": "npm run dev",
    "preview": "vite --config vite.site.config.ts preview --host",
    "test:fixture:vite:install": "node ../tests/fixtures/install-packed-package.mjs vite-basic",
    "test:fixture:vite:build": "npm run test:fixture:vite:install && npm --prefix ../tests/fixtures/vite-basic run build",
    "test:fixture:vite:serve-dev": "npm --prefix ../tests/fixtures/vite-basic run dev -- --host 127.0.0.1 --port 4174",
    "test:fixture:vite:serve-static": "npm --prefix ../tests/fixtures/vite-basic run preview -- --host 127.0.0.1 --port 4175",
    "test:fixture:vite": "npm run test:fixture:vite:build && NODE_PATH=./node_modules FIXTURE_GROUP=vite playwright test --config ../tests/playwright.config.ts --project=vite-dev-chromium --project=vite-dev-firefox --project=vite-static-chromium --project=vite-static-firefox",
    "test:fixture:webpack:install": "node ../tests/fixtures/install-packed-package.mjs webpack-basic",
    "test:fixture:webpack:build": "npm run test:fixture:webpack:install && npm --prefix ../tests/fixtures/webpack-basic run build",
    "test:fixture:webpack:serve": "npm --prefix ../tests/fixtures/webpack-basic run serve",
    "test:fixture:webpack:serve-static": "npm --prefix ../tests/fixtures/webpack-basic run serve-static",
    "test:fixture:webpack": "npm run test:fixture:webpack:build && NODE_PATH=./node_modules FIXTURE_GROUP=webpack playwright test --config ../tests/playwright.config.ts --project=webpack-dev-chromium --project=webpack-dev-firefox --project=webpack-static-chromium --project=webpack-static-firefox",
    "test:fixture:rollup:install": "node ../tests/fixtures/install-packed-package.mjs rollup-basic",
    "test:fixture:rollup:build": "npm run test:fixture:rollup:install && npm --prefix ../tests/fixtures/rollup-basic run build && cp ../tests/fixtures/rollup-basic/index.html ../tests/fixtures/rollup-basic/dist/index.html",
    "test:fixture:rollup:serve-static": "npm --prefix ../tests/fixtures/rollup-basic run serve-static",
    "test:fixture:rollup": "npm run test:fixture:rollup:build && NODE_PATH=./node_modules FIXTURE_GROUP=rollup playwright test --config ../tests/playwright.config.ts --project=rollup-static-chromium --project=rollup-static-firefox",
    "test:fixture:deno:install": "node ../tests/fixtures/install-packed-package.mjs deno-basic",
    "test:fixture:deno": "npm run test:fixture:deno:install && npm --prefix ../tests/fixtures/deno-basic run test",
    "test:fixture:node:install": "node ../tests/fixtures/install-packed-package.mjs node-basic",
    "test:fixture:node": "npm run test:fixture:node:install && npm --prefix ../tests/fixtures/node-basic run test",
    "test:fixture:bun:install": "node ../tests/fixtures/install-packed-package.mjs bun-basic",
    "test:fixture:bun": "npm run test:fixture:bun:install && npm --prefix ../tests/fixtures/bun-basic run test",
    "test:fixtures:browser": "npm run test:fixture:vite && npm run test:fixture:webpack && npm run test:fixture:rollup",
    "test:fixtures:runtime": "npm run test:fixture:deno && npm run test:fixture:node && npm run test:fixture:bun",
    "test:fixtures:full": "npm run test:fixtures:browser && npm run test:fixtures:runtime",
    "test:fixtures": "npm run test:fixtures:full"
  },
  "files": [
    "build/javascript/lib/*.d.ts",
    "build/javascript/wasm",
    "build/javascript/browser",
    "build/javascript/node",
    "build/javascript/node-wasm"
  ],
  "dependencies": {
    "protobufjs": "^7.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.14.15",
    "esbuild": "^0.27.7",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  },
  "keywords": [
    "or-tools",
    "ortools",
    "google-or-tools",
    "optimization",
    "operations-research",
    "constraint-programming",
    "constraint-solver",
    "cp-sat",
    "sat",
    "linear-programming",
    "integer-programming",
    "mixed-integer-programming",
    "mip",
    "milp",
    "mathopt",
    "vehicle-routing",
    "vrp",
    "tsp",
    "route-optimization",
    "scheduling",
    "timetabling",
    "assignment",
    "bin-packing",
    "knapsack",
    "network-flow",
    "wasm",
    "webassembly",
    "typescript",
    "javascript",
    "browser",
    "solver",
    "combinatorial-optimization",
    "mathematical-optimization",
    "job-shop-scheduling",
    "delivery-routing",
    "client-side"
  ],
  "description": "Google OR-Tools compiled to WebAssembly for TypeScript, JavaScript, browser and Node. Supports CP-SAT, Routing, MIP, MathOpt, vehicle routing, scheduling, linear programming and constraint optimization."
}
